# ============================================================================
# LangChain 1.0 学习仓库 - 环境变量配置模板
# ============================================================================
# 使用说明：
# 1. 复制此文件并重命名为 .env
# 2. 填入你的实际 API Keys
# 3. .env 文件已在 .gitignore 中，不会被提交到 Git
# ============================================================================
#
# 💰 免费 API 推荐（2025年）：
# ⭐⭐⭐ Groq API - 完全免费，超快速度，LangChain 原生支持
# ⭐⭐⭐ Google Gemini - 免费额度慷慨（每分钟15次请求）
# ⭐⭐ DeepSeek - 成本极低（仅为 OpenAI 的 2%）
# ⭐⭐ Claude - 学生/研究者免费 $500 额度
# ⭐ Together AI、Hugging Face - 免费层可用
# ============================================================================

# ----------------------------------------------------------------------------
# ⭐⭐⭐ Groq API 配置（强烈推荐！完全免费 + 超快速度）
# ----------------------------------------------------------------------------
# 获取地址: https://console.groq.com/keys
# 特点:
#   - 完全免费，无需信用卡
#   - 速度极快（使用 LPU 硬件加速）
#   - 原生支持 LangChain（langchain-groq 包）
#   - 支持 Llama 3.3 70B, Mixtral 等开源模型
# 安装: pip install langchain-groq
GROQ_API_KEY=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

# ----------------------------------------------------------------------------
# OpenAI API 配置
# ----------------------------------------------------------------------------
# 获取地址: https://platform.openai.com/api-keys
# 用于: GPT-4, GPT-3.5 等模型
OPENAI_API_KEY=your_openai_api_key_here

# 可选：OpenAI API Base URL（如果使用代理或自定义端点）
# OPENAI_API_BASE=https://api.openai.com/v1

# 可选：OpenAI 组织 ID
# OPENAI_ORGANIZATION=your_org_id_here

# ----------------------------------------------------------------------------
# Anthropic API 配置
# ----------------------------------------------------------------------------
# 获取地址: https://console.anthropic.com/
# 用于: Claude 系列模型
# 💰 免费额度途径：
#   1. 学生计划：https://anthropic.com/students - 免费 $500 额度
#   2. 研究者计划：https://anthropic.com/research - AI 安全研究免费额度
#   3. 云平台赠金：通过 AWS Bedrock 或 Google Vertex AI 获取 $300+ 额度
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ----------------------------------------------------------------------------
# LangSmith 配置（可观测性平台）
# ----------------------------------------------------------------------------
# 获取地址: https://smith.langchain.com/
# 用于: Agent 追踪、调试、评估
LANGSMITH_API_KEY=your_langsmith_api_key_here

# 启用 LangSmith 追踪（true/false）
LANGSMITH_TRACING=false

# LangSmith 项目名称
LANGSMITH_PROJECT=langchain-v1-study

# LangSmith 端点（通常不需要修改）
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ----------------------------------------------------------------------------
# ⭐⭐⭐ Google Gemini API 配置（推荐！免费额度慷慨）
# ----------------------------------------------------------------------------
# 获取地址: https://aistudio.google.com/apikey
# 免费额度:
#   - 每分钟 15 次请求
#   - 每天 1500 次请求
#   - Gemini 1.5 Flash 和 Pro 都免费
# 用于: Gemini Pro, Gemini Flash 等模型
# 安装: pip install langchain-google-genai
GOOGLE_API_KEY=your_google_api_key_here

# ----------------------------------------------------------------------------
# ⭐⭐ DeepSeek API 配置（成本极低）
# ----------------------------------------------------------------------------
# 获取地址: https://platform.deepseek.com/
# 特点:
#   - 成本仅为 OpenAI 的 2%
#   - 性能接近 GPT-4
#   - 128K 上下文窗口
# 价格: $0.28/1M input tokens, $0.42/1M output tokens
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ----------------------------------------------------------------------------
# Cohere API 配置（可选）
# ----------------------------------------------------------------------------
# 获取地址: https://dashboard.cohere.com/api-keys
# 用于: Cohere 模型
# COHERE_API_KEY=your_cohere_api_key_here

# ----------------------------------------------------------------------------
# HuggingFace API 配置（可选）
# ----------------------------------------------------------------------------
# 获取地址: https://huggingface.co/settings/tokens
# 用于: HuggingFace 模型和 Embeddings
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ----------------------------------------------------------------------------
# 向量数据库配置（用于 RAG 项目 - Module 13, 14）
# ----------------------------------------------------------------------------

# ⭐⭐⭐ Pinecone（推荐！免费 serverless 层级）
# 获取地址: https://www.pinecone.io/
# 免费层级:
#   - 1 个 serverless 索引
#   - 10 GB 存储
#   - 无限请求（有速率限制）
#   - 无需信用卡
# 使用区域: us-east-1 (AWS) - 免费
# 安装: pip install langchain-pinecone pinecone-client
PINECONE_API_KEY=pcsk_3JKq4n_72GT8qNQ7i6b4rf3kNqswNFKdGwM7cByCVCKkaTTFekqr4e4MxWg5NL3Fw8psaP

# Weaviate（可选）
# WEAVIATE_URL=your_weaviate_url_here
# WEAVIATE_API_KEY=your_weaviate_api_key_here

# ----------------------------------------------------------------------------
# 搜索引擎 API 配置（用于 Web 搜索工具）
# ----------------------------------------------------------------------------

# Tavily Search API（推荐用于 AI 搜索）
# 获取地址: https://tavily.com/
# TAVILY_API_KEY=your_tavily_api_key_here

# Serper API（Google 搜索）
# 获取地址: https://serper.dev/
# SERPER_API_KEY=your_serper_api_key_here

# SerpAPI（Google 搜索）
# 获取地址: https://serpapi.com/
# SERPAPI_API_KEY=your_serpapi_api_key_here

# ----------------------------------------------------------------------------
# 数据库配置（用于 Checkpointing）
# ----------------------------------------------------------------------------

# PostgreSQL（可选）
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=langchain_checkpoints
# POSTGRES_USER=your_username
# POSTGRES_PASSWORD=your_password

# ----------------------------------------------------------------------------
# 应用配置
# ----------------------------------------------------------------------------

# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
LOG_LEVEL=INFO

# 开发模式（true/false）
DEV_MODE=true

# 最大重试次数
MAX_RETRIES=3

# 请求超时时间（秒）
REQUEST_TIMEOUT=30

# ----------------------------------------------------------------------------
# 模型默认配置
# ----------------------------------------------------------------------------

# 默认使用的模型
DEFAULT_MODEL=openai:gpt-4

# 默认温度参数（0.0 - 2.0）
DEFAULT_TEMPERATURE=0.7

# 默认最大 Token 数
DEFAULT_MAX_TOKENS=2000

# ----------------------------------------------------------------------------
# 注意事项
# ----------------------------------------------------------------------------
# 1. 永远不要提交包含真实 API Keys 的 .env 文件到 Git
# 2. 定期轮换你的 API Keys 以保证安全
# 3. 使用最小权限原则，只授予必要的权限
# 4. 监控 API 使用情况，避免意外高额费用
# 5. 在生产环境中使用环境变量或密钥管理服务
# ============================================================================
